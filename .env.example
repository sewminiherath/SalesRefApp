# Copy to .env.local for local development.
# On Vercel: set the same variable in Project → Settings → Environment Variables (Production).

# Public URL of the Express API, must end with /api
# Local:
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Same Wi‑Fi from phone (use your PC's LAN IP):
# NEXT_PUBLIC_API_URL=http://192.168.1.100:5000/api
# Production (example — replace with your real API host):
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api

NEXT_PUBLIC_API_URL=http://localhost:5000/api

# --- Railway (backend service only) ---
# In Railway → your API service → Variables, set:
#   DATA_DIR=/data
#   DB_PATH=/data/ebilling.sqlite
# In Railway → Volumes: add a volume, mount path /data (persists SQLite across deploys).
# PORT is set automatically by Railway.
# After deploy, use the public URL as: https://YOUR-SERVICE.up.railway.app/api
# and set NEXT_PUBLIC_API_URL on Vercel/GitHub Pages to that value.

# Backend persistence variables (set on backend host like Railway):
# DATA_DIR=/data
# DB_PATH=/data/ebilling.sqlite

# --- SMTP email (backend service) ---
# Example for Gmail SMTP (use App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=your-email@gmail.com
# Optional default company recipient for invoice copies:
# EMAIL_TO=accounts@yourcompany.com
# Optional timeout in milliseconds (default: 15000):
# SMTP_TIMEOUT_MS=15000
