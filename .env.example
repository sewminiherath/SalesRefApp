# Copy to .env.local for local development.
# On Vercel: set the same variable in Project → Settings → Environment Variables (Production).

# Public URL of the Express API, must end with /api
# Local:
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Same Wi‑Fi from phone (use your PC's LAN IP):
# NEXT_PUBLIC_API_URL=http://192.168.1.100:5000/api
# Production (example — replace with your real API host):
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api

NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Backend persistence variables (set on backend host like Railway):
# DATA_DIR=/data
# DB_PATH=/data/ebilling.sqlite
