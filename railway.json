{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm ci",
    "watchPatterns": [
      "backend/**",
      "package.json",
      "package-lock.json",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run start:backend",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
